FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git

WORKDIR /app

COPY translator/go.mod translator/go.sum* ./
RUN go mod download 2>/dev/null; true

COPY translator/*.go ./
RUN go mod tidy && CGO_ENABLED=0 GOOS=linux go build -o /translator .

FROM alpine:3.20

RUN apk add --no-cache ca-certificates brotli && mkdir -p /data

COPY --from=builder /translator /usr/local/bin/translator

EXPOSE 1344
VOLUME /data

CMD ["translator"]
