FROM golang:1.22-alpine AS builder

WORKDIR /app

COPY translator/go.mod ./
COPY translator/*.go ./

RUN CGO_ENABLED=0 GOOS=linux go build -o /translator .

FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY --from=builder /translator /usr/local/bin/translator

EXPOSE 1344

CMD ["translator"]
